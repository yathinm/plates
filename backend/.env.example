# PostgreSQL + TimescaleDB
POSTGRES_USER=plates_admin
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=plates
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql://plates_admin:<your-postgres-password>@db:5432/plates

# Redis (use REDIS_PORT=6380 + REDIS_HOST=localhost only for host `npm run dev` hitting mapped Redis; `api` in Compose uses 6379 on the internal network)
REDIS_PORT=6379
REDIS_HOST_PORT=6380
REDIS_PASSWORD=<your-redis-password>

# API Server
API_PORT=3000
API_HOST_PORT=3002
JWT_SECRET=<your-jwt-secret>
NODE_ENV=development
